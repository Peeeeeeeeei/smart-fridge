{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    
    /* Vite Bundler 必備設定 */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    
    /* React JSX 設定 */
    "jsx": "react-jsx",
    "esModuleInterop": true,
    
    /* 嚴格模式與路徑檢查 */
    "strict": true,
    "skipLibCheck": true,
    "types": ["node", "vite/client"],
    "paths": {
      "@/*": ["./client/src/*"],
      "@shared/*": ["./shared/*"]
    }
  },
  "include": [
    "client/src/**/*", 
    "shared/**/*",
    "server/**/*" 
  ],
  "exclude": [
    "node_modules", 
    "build", 
    "dist", 
    "**/*.test.ts"
  ]
}